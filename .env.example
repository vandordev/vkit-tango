# Required by Go runtimes. These credentials match the local PostgreSQL
# baseline when it is available on localhost:5432.
DATABASE_URL=postgresql://boilerplate:boilerplate@localhost:5432/boilerplate

# Required server-only secrets. Replace these development values before any
# shared or deployed environment; never expose them to the browser.
REALTIME_TICKET_SECRET=replace-with-a-local-ticket-secret
REALTIME_INTERNAL_API_KEY=replace-with-a-local-internal-api-key

# Optional local overrides. These values already match the YAML defaults and
# are included to make ports, concurrency, and browser-facing URLs explicit.
API_HOST=0.0.0.0
API_PORT=4101
REALTIME_PORT=4102
REALTIME_PUBLIC_URL=http://localhost:4102
WORKER_MAX_WORKERS=10
WEB_API_BASE_URL=http://localhost:4101
WEB_REALTIME_URL=http://localhost:4102
