# Required local database connection.
DATABASE_URL=postgresql://user:password@localhost:5432/boilerplate
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=4101
API_PUBLIC_BASE_URL=http://localhost:4101
WEB_API_BASE_URL=http://localhost:4101
WEB_REALTIME_URL=http://localhost:4102
REALTIME_HOST=0.0.0.0
REALTIME_PUBLIC_URL=http://localhost:4102
REALTIME_INTERNAL_API_KEY=replace-with-a-local-secret
WORKER_MAX_WORKERS=10
WORKER_SHUTDOWN_TIMEOUT_SECONDS=30

# Optional runtime overrides.
NODE_ENV=development
LOG_LEVEL=debug
PORT=4101
CORS_ORIGIN=http://localhost:4100
OPENAPI_SERVER_URL=http://localhost:4101
WORKER_POLL_INTERVAL_MS=1000
SCHEDULER_POLL_INTERVAL_MS=1000
REALTIME_PORT=4102

# Optional OpenAPI protection.
OPENAPI_BASIC_AUTH_USERNAME=
OPENAPI_BASIC_AUTH_PASSWORD=

# Required when selecting the realtime module.
REALTIME_TICKET_SECRET=replace-with-a-local-secret
REALTIME_PUBLISH_API_KEY=replace-with-a-local-secret

# Optional private S3/MinIO object storage.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_ROOT_PREFIX=uploads
