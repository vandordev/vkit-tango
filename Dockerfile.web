# syntax=docker/dockerfile:1.11
FROM oven/bun:1.3.14-alpine AS base
WORKDIR /app
FROM base AS prepare
COPY . .
RUN --mount=type=cache,id=bun-web-prune,target=/root/.bun/install/cache \
    bunx turbo@2.10.5 prune web --docker
FROM base AS deps
COPY --from=prepare /app/out/json/ ./
RUN --mount=type=cache,id=bun-web-install,target=/root/.bun/install/cache \
    bun install --frozen-lockfile --ignore-scripts
FROM oven/bun:1.3.14-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/config/node_modules ./packages/config/node_modules
COPY --from=prepare /app/out/full/ ./
RUN mkdir -p /runtime/config-node-modules && cp -LR packages/config/node_modules/. /runtime/config-node-modules/
ENV NODE_ENV=production
ARG DATABASE_URL
ENV DATABASE_URL=$DATABASE_URL
COPY config /app/config
RUN --mount=type=cache,id=tanstack-web-build,target=/app/apps/web/.vite \
    cd apps/web && bun run ../../packages/config/src/run.ts --modules web -- bun run vite build
FROM oven/bun:1.3.14-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=4100
ENV HOSTNAME=0.0.0.0
RUN addgroup --system --gid 1001 app && adduser --system --uid 1001 --ingroup app app
COPY --from=builder --chown=app:app /app/apps/web/.output ./.output
COPY --from=builder --chown=app:app /app/packages/config ./packages/config
RUN rm -rf ./packages/config/node_modules
COPY --from=builder --chown=app:app /runtime/config-node-modules ./packages/config/node_modules
COPY --from=builder --chown=app:app /app/config ./config
USER app
EXPOSE 4100
CMD ["bun", "run", "packages/config/src/run.ts", "--modules", "web", "--", "bun", ".output/server/index.mjs"]
