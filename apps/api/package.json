{
	"name": "@repo/api",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"dev": "bun --env-file=../../.env run ../../packages/config/src/run.ts --modules base,api,storage -- bun run --watch src/server.ts",
		"build": "bun build src/server.ts --outdir=dist --target=bun",
		"start": "bun --env-file=../../.env run ../../packages/config/src/run.ts --modules base,api,storage -- bun run dist/server.js",
		"lint": "eslint",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.3.5",
		"@elysiajs/openapi": "^1.4.15",
		"@repo/config": "*",
		"@repo/database": "*",
		"@repo/storage": "*",
		"elysia": "^1.4.21",
		"pino": "^9.7.0",
		"pino-pretty": "^13.0.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@repo/eslint-config": "*",
		"@repo/typescript-config": "*",
		"@types/bun": "latest",
		"eslint": "^9.39.1",
		"prisma": "^6.0.0",
		"typescript": "5.9.2"
	}
}
