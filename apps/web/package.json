{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env run ../../packages/config/src/run.ts --modules web -- bun run vite --port 4100",
    "build": "NODE_ENV=production bun --env-file=../../.env run ../../packages/config/src/run.ts --modules web -- bun run vite build",
    "start": "bun --env-file=../../.env run ../../packages/config/src/run.ts --modules web -- bun .output/server/index.mjs",
    "api:generate": "openapi-ts",
    "lint": "eslint",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .output .vite src/routeTree.gen.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.30",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "nitro": "3.0.260610-beta",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@tanstack/router-plugin": "1.168.22",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vite": "8.1.5"
  }
}
