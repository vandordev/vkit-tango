{
  "name": "turbostack",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun run check-types && turbo run build",
    "start": "bun run start:web",
    "start:core": "bun run start:web",
    "start:jobs": "go run ./apps/worker",
    "start:api": "go run ./apps/api",
    "start:web": "cd apps/web && bun run start",
    "start:worker": "go run ./apps/worker",
    "start:realtime": "cd apps/realtime && bun run start",
    "dev": "turbo run dev --filter=web",
    "dev:standalone-api": "go run ./apps/api",
    "dev:jobs": "go run ./apps/worker",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "go run ./apps/api",
    "dev:worker": "go run ./apps/worker",
    "dev:realtime": "turbo run dev --filter=@repo/realtime-server",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "docker:build:web": "turbo run build --filter=web",
    "docker:build:api": "docker build -f Dockerfile.api .",
    "check:tasks": "bun run scripts/check-task-surface.ts",
    "check:architecture-docs": "bun run scripts/check-architecture-docs.ts",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {}
}
