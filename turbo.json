{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": [
		"NODE_ENV",
		"LOG_LEVEL",
		"NEXT_PUBLIC_APP_URL",
		"DATABASE_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
			".next/**",
				"!.next/cache/**",
				"dist/**"
			],
			"env": [
				"NEXT_PUBLIC_APP_URL"
			]
		},
		"web#build": {
			"env": [
				"NEXT_PRIVATE_SKIP_PATCHING"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			],
			"outputs": []
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		}
	}
}
