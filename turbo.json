{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": [
		"NODE_ENV",
		"LOG_LEVEL",
		"DATABASE_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
			".output/**",
				"!.output/cache/**",
				"dist/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			],
			"outputs": []
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		}
	}
}
